    "pg": "^8.16.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.15.5",
    "bun-types": "^1.3.3",
    "typescript": "^5.9.2"
  }
}
